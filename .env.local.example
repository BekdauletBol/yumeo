# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_HERE

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get keys from https://app.supabase.com → Project Settings → API
# ⚠️ ANON_KEY is safe to expose (it's for client)
# ⚠️ SERVICE_ROLE_KEY must NEVER be exposed (keep in server env only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET_HERE

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# ⚠️ PUBLISHABLE_KEY is safe to expose (it's public)
# ⚠️ SECRET_KEY must NEVER be exposed (keep in server env only)
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Create a Product + Price in Stripe dashboard → Products, then paste the price ID
STRIPE_PRO_PRICE_ID=price_YOUR_PRICE_ID

# Webhook secret — from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# or from Stripe dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3010

# ─── GitHub ───────────────────────────────────────────────────────────────────
# GitHub Personal Access Token (with repo and gist scopes)
# 🔒 NEVER commit this! Use GitHub Actions secrets instead
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# ─── GitHub Models (OpenAI-compatible) ────────────────────────────────────────
# Your GitHub PAT with Models:read scope — used to call GPT-4o via GitHub's API
# 🔒 NEVER commit this! Use GitHub Actions secrets instead
GITHUB_MODELS_TOKEN=ghp_YOUR_TOKEN_HERE
# Which model to use (see https://github.com/marketplace/models)
GITHUB_MODELS_MODEL=gpt-4o

# ─── Setup Instructions ────────────────────────────────────────────────────────
# 1. Copy this file to .env.local
# 2. Replace all placeholder values with actual keys from respective dashboards
# 3. ⚠️ NEVER commit .env.local to git
# 4. ⚠️ For production, use Vercel Environment Variables, not .env files
# 5. Run: npm install && npm run dev
# 
# Production Deployment:
# - Add all secret keys to Vercel Project Settings → Environment Variables
# - Use GitHub Actions Secrets for CI/CD
# - Rotate all keys quarterly
# - Enable key versioning and rotation policies in each service

